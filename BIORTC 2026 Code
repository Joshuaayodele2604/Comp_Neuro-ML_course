        "input[pulsesat] = 3\n",
        "\n",
        "rate = np.ones((Nt,))\n",
        "\n",
        "tau = 0.02\n",
        "J = 1   #try 1, 0.05, 7, 9,\n",
        "\n",
        "input = input*np.abs(1-J)\n",
        "for i in range(Nt-1):\n",
